# Image that your server admin will load/import
POSTAL_IMAGE=postal-fork:handover

# Runtime
RAILS_ENVIRONMENT=production
WEB_PORT=5000
SMTP_PORT=25
POSTAL_WEB_PROTOCOL=https
POSTAL_WEB_HOSTNAME=mail.example.com
POSTAL_SMTP_HOSTNAME=mail.example.com

# Database (container + app connection)
MARIADB_DATABASE=postal
MARIADB_ROOT_PASSWORD=change-me-root
MAIN_DB_USERNAME=root
MAIN_DB_PASSWORD=change-me-root
MESSAGE_DB_USERNAME=root
MESSAGE_DB_PASSWORD=change-me-root
